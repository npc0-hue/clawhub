# ===========================================
# Convex 后端环境变量（部署到 Convex Cloud）
# ===========================================
# 使用说明：
# 1. 复制此文件为 convex.env
# 2. 填入所有必填配置
# 3. 运行：bunx convex env set --env-file convex.env
# ===========================================

# ===========================================
# GitHub OAuth（必填）
# ===========================================
# 在 https://github.com/settings/developers 创建 OAuth App
# Callback URL: https://your-convex-deployment.convex.cloud/api/auth/callback/github

AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret

# ===========================================
# JWT 密钥（必填）
# ===========================================
# 使用 @convex-dev/auth CLI 生成：
# bunx @convex-dev/auth secret-key generate

JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
JWKS='{"keys":[{"kty":"RSA","kid":"your-key-id","use":"sig","alg":"RS256","n":"your-modulus","e":"your-exponent","d":"your-private-exponent","p":"your-p","q":"your-q","dp":"your-dp","dq":"your-dq","qi":"your-qi"}]}'

# ===========================================
# Embeddings（可选，用于向量搜索）
# ===========================================

OPENAI_API_KEY=sk-your-openai-api-key

# ===========================================
# 其他配置（可选）
# ===========================================

# 站点模式
SITE_MODE=production

# SoulHub 配置（如果需要）
SOULHUB_SITE_URL=
SOULHUB_HOST=
