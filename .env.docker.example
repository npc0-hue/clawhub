# ===========================================
# ClawHub Docker 环境配置示例
# ===========================================
# 使用说明：
# 1. 复制此文件为 .env.docker
# 2. 填入所有必填配置
# 3. 运行：docker compose up -d
# ===========================================

# ===========================================
# 网络配置（外网访问必需）
# ===========================================

# 宿主机端口映射（默认 3000）
HOST_PORT=3000

# 站点完整 URL（用于外网访问，例如：https://clawhub.example.com）
SITE_URL=https://your-domain.com

# Convex 站点 URL（通常与 SITE_URL 相同）
CONVEX_SITE_URL=https://your-domain.com

# ===========================================
# Convex 配置（必填）
# ===========================================

# Convex 部署 URL（从 Convex Dashboard 获取）
VITE_CONVEX_URL=https://your-convex-deployment.convex.cloud

# Convex 站点 URL（通常与 SITE_URL 相同）
VITE_CONVEX_SITE_URL=https://your-domain.com

# ===========================================
# Convex Auth - GitHub OAuth（必填）
# ===========================================
# 在 GitHub Developer Settings -> OAuth Apps 创建
# Callback URL: https://your-domain.com/api/auth/callback/github

AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret

# ===========================================
# Convex Auth - JWT Keys（必填）
# ===========================================
# 使用 @convex-dev/auth CLI 生成：
# bunx @convex-dev/auth secret-key generate

JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----
JWKS={"keys":[{"kty":"RSA","kid":"your-key-id","use":"sig","alg":"RS256","n":"your-modulus","e":"your-exponent","d":"your-private-exponent","p":"your-p","q":"your-q","dp":"your-dp","dq":"your-dq","qi":"your-qi"}]}

# ===========================================
# Embeddings（可选，用于向量搜索）
# ===========================================

OPENAI_API_KEY=sk-your-openai-api-key

# ===========================================
# 其他配置（可选）
# ===========================================

VITE_SOULHUB_SITE_URL=
VITE_SOULHUB_HOST=
VITE_SITE_MODE=
